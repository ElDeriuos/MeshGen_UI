# ── Rust build artefacts ──────────────────────────────────────────────────────
/mesh_gui/target/
/structured_mesh/target/

# Keep Cargo.lock for executables (mesh_gui), exclude for libraries
# mesh_gui/Cargo.lock is committed (it is an application)
# structured_mesh/Cargo.lock is excluded (it is a library)
structured_mesh/Cargo.lock

# rustfmt backup files
**/*.rs.bk

# ── C++ build artefacts ───────────────────────────────────────────────────────
EasyMesh/Src/*.o
# catch any nested .o files
**/*.o

# EasyMesh binaries built in-place (the root copies are the release artefacts)
EasyMesh/Src/Easy
EasyMesh/Src/Easy.exe

# ── Root-level compiled binaries (release outputs — do not commit) ────────────
/meshgen_ui
/meshgen_ui.exe
/Easy
/Easy.exe

# ── Default output directory ──────────────────────────────────────────────────
/outputs/

# ── Structured mesh output files ──────────────────────────────────────────────
*.vtu
*.plt

# ── EasyMesh output files ─────────────────────────────────────────────────────
*.n
*.e
*.s
*.dat
*.eps
*.vtk

# ── Structured mesh example outputs (keep input files only) ───────────────────
structured_mesh/examples/**/*.vtu
structured_mesh/examples/**/*.plt
structured_mesh/examples/**/*.txt

# ── EasyMesh example outputs (keep .d input files only) ───────────────────────
EasyMesh/Examples/*.n
EasyMesh/Examples/*.e
EasyMesh/Examples/*.s
EasyMesh/Examples/*.dat
EasyMesh/Examples/*.eps
EasyMesh/Examples/*.vtk

# ── Project / editor files ────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS-generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Saved project files (user-generated, not part of the source) ─────────────
*.json
